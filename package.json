{
  "name": "intaektalk-fe",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b",
    "preview": "npm run build && wrangler dev",
    "gen:api": "openapi-typescript src/lib/api/openapi.json -o src/lib/api/schema.d.ts",
    "gen:api:remote": "openapi-typescript https://api.khmin.cloud/docs-json -o src/lib/api/schema.d.ts",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "@channel.io/bezier-icons": "^0.59.0",
    "@channel.io/bezier-react": "^3.6.6",
    "@channel.io/bezier-tokens": "^0.6.0",
    "@tanstack/react-query": "^5.101.0",
    "openapi-fetch": "^0.17.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.78.0",
    "react-router-dom": "^6.30.4",
    "socket.io-client": "^4.8.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.42.1",
    "@types/node": "^25.9.2",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^6.0.2",
    "openapi-typescript": "^7.13.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "wrangler": "^4.103.0"
  }
}
