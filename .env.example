# REST API 베이스 URL (백엔드 v2.0 명세)
VITE_API_BASE_URL=https://localhost:3000

# Socket.IO 서버 origin (네임스페이스 /ws 는 코드에서 붙는다)
VITE_WS_URL=https://localhost:3000

# Kakao JavaScript SDK 앱 키 (Kakao Developers > 앱 > JavaScript 키)
VITE_KAKAO_JS_KEY=

# 웹 푸시 VAPID 공개키 (base64url). 비워두면 푸시 구독을 시도하지 않는다
VITE_VAPID_PUBLIC_KEY=
